# Test 3 - intentar conectar al proxy por IPv6 sin bindtodevice
print("\n[3] Proxy IPv6 SIN bindtodevice:")
try:
    s = socket.socket(socket.AF_INET6, socket.SOCK_STREAM)
    s.settimeout(5)
    s.connect(("2606:4700::6812:16b7", 80, 0, 0))
    s.sendall(b"GET / HTTP/1.1\r\nHost: emailmarketing.personal.com.ar\r\n\r\n")
    time.sleep(0.5)
    s.settimeout(3)
    r = b""
    try:
        while True:
            c = s.recv(4096)
            if not c: break
            r += c
