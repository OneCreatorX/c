#!/usr/bin/env python3
# Test - ver IP publica que ve el servidor
import socket, time

IFACE = b"enxa622d9c52ba3"

print("=== Test: IP publica desde la interfaz del celular ===")

# Test 1 - sin bindtodevice (ruta normal)
print("\n[1] IP publica SIN bindtodevice:")
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(5)
    s.connect(("104.18.22.183", 80))
    s.sendall(b"GET / HTTP/1.1\r\nHost: ifconfig.me\r\n\r\n")
    time.sleep(1)
    s.settimeout(2)
    r = b""
    try:
        while True:
            c = s.recv(4096)
            if not c: break
            r += c
    except: pass
    print(r.decode(errors="replace")[-200:])
    s.close()
except Exception as e:
    print(f"  Error: {e}")

# Test 2 - con bindtodevice (interfaz celular)
print("\n[2] IP publica CON bindtodevice (interfaz celular):")
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_BINDTODEVICE, IFACE)
    s.settimeout(5)
    s.connect(("104.18.22.183", 80))
    s.sendall(b"GET / HTTP/1.1\r\nHost: ifconfig.me\r\n\r\n")
    time.sleep(1)
