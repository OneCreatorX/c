#!/usr/bin/env python3
# Test de conexion — fuerza salida por usb0
import socket, time, sys

CLIENT_ID   = "sz67pu5p"
PROXY_HOST  = "emailmarketing.personal.com.ar"
PROXY_IPV6  = "2606:4700::6812:16b7"
PROXY_PORT  = 80
TUNNEL_HOST = "1.brawlpass.com.ar"
USB_IFACE   = b"enxa622d9c52ba3"

print("=== Test 1: Detectar interfaz USB ===")
import subprocess
result = subprocess.run(["ip", "link", "show"], capture_output=True, text=True)
for line in result.stdout.splitlines():
    if "usb" in line.lower() or "enp" in line.lower():
        print(" ", line.strip())
print()

print("=== Test 2: Resolver DNS por usb0 ===")
addrs = []
try:
    r = socket.getaddrinfo(PROXY_IPV6, PROXY_PORT, socket.AF_INET6, socket.SOCK_STREAM)
    addrs.append((r[0][4], socket.AF_INET6))
    print(f"  IPv6: {PROXY_IPV6} ok")
except Exception as e:
    print(f"  IPv6 fallo: {e}")
try:
    r = socket.getaddrinfo(PROXY_HOST, PROXY_PORT, socket.AF_INET, socket.SOCK_STREAM)
    for info in r:
        addrs.append((info[4], socket.AF_INET))
        print(f"  IPv4: {info[4][0]} ok")
except Exception as e:
    print(f"  IPv4 fallo: {e}")
print()

print("=== Test 3: Conectar socket por usb0 ===")
sock = None
for addr, fam in addrs:
    try:
        s = socket.socket(fam, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_BINDTODEVICE, USB_IFACE)
        s.settimeout(10)
        s.connect(addr)
        s.settimeout(None)
        sock = s
        print(f"  Conectado a {addr[0]}")
        break
    except Exception as e:
        print(f"  Fallo {addr[0]}: {e}")
if not sock:
    print("  ERROR: Sin conexion por usb0")
    print("  Verificar: celular conectado con 'Compartir internet por USB' activo")
    sys.exit(1)
print()

print("=== Test 4: Handshake P1 / P2 ===")
sock.sendall(f"GET / HTTP/1.1\r\nHost: {PROXY_HOST}\r\n\r\n".encode())
print("  P1 enviado")
time.sleep(0.01)
t0 = time.time()
sock.sendall((
    f"- / HTTP/1.1\r\nHost: {TUNNEL_HOST}\r\nUpgrade: websocket\r\n"
    f"Action: tunnel\r\nX-Client-Id: {CLIENT_ID}\r\n\r\n"
).encode())
print("  P2 enviado")
sock.settimeout(8)
raw = b""
try:
    while b"\r\n\r\n" not in raw:
        c = sock.recv(4096)
        if not c: break
        raw += c
except socket.timeout:
    print("  TIMEOUT")
    sock.close()
    sys.exit(1)
ms = int((time.time() - t0) * 1000)
print(f"  Respuesta en {ms}ms")
print()
print("--- RESPUESTA ---")
print(raw.decode(errors="replace"))
print("-----------------")
print()
if b"101" in raw[:30]:
    print("EXITO: tunel establecido correctamente")
else:
    print("ERROR: no se recibio 101")
sock.close()
