#!/bin/bash
# Test WiFi — crea red abierta y muestra trafico
# Uso: bash wifi-test.sh

WIFI=wlp2s0
IP=192.168.99.1

echo "Instalando hostapd y dnsmasq..."
apt-get install -y -q hostapd dnsmasq tcpdump

echo "Configurando interfaz WiFi..."
ip link set $WIFI down
ip link set $WIFI up
ip addr flush dev $WIFI
ip addr add $IP/24 dev $WIFI

echo "Creando config hostapd..."
cat > /tmp/hostapd-test.conf << EOF
interface=$WIFI
driver=nl80211
ssid=XTunnel-Test
hw_mode=g
channel=6
auth_algs=1
EOF

echo "Creando config dnsmasq..."
cat > /tmp/dnsmasq-test.conf << EOF
interface=$WIFI
dhcp-range=192.168.99.100,192.168.99.200,255.255.255.0,1h
dhcp-option=3,$IP
dhcp-option=6,8.8.8.8
EOF

pkill -f hostapd 2>/dev/null || true
pkill -f "dnsmasq -C /tmp/dnsmasq" 2>/dev/null || true
sleep 1

echo "Iniciando hostapd..."
hostapd -B /tmp/hostapd-test.conf -P /tmp/hostapd-test.pid

echo "Iniciando dnsmasq..."
dnsmasq -C /tmp/dnsmasq-test.conf

echo ""
echo "=============================="
echo "  Red WiFi: XTunnel-Test"
echo "  Sin contraseña"
echo "  IP gateway: $IP"
echo "=============================="
echo ""
echo "Conectate al WiFi y mira el trafico:"
echo ""

tcpdump -i $WIFI -n 2>/dev/null
