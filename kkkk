#!/bin/bash
# XTunnel PC — iniciar todo
# Uso: bash start.sh

WIFI=wlp2s0
GW_IP=192.168.99.1

# Detectar interfaz USB automaticamente
USB=$(ip route | awk '/default/{print $5}' | head -1)
echo "USB detectado: $USB"
echo "WiFi: $WIFI"
echo ""

# Crear configs
cat > /tmp/hostapd.conf << EOF
interface=$WIFI
driver=nl80211
ssid=XTunnel-Test
hw_mode=g
channel=6
auth_algs=1
EOF

cat > /tmp/dnsmasq.conf << EOF
interface=$WIFI
dhcp-range=192.168.99.100,192.168.99.200,255.255.255.0,1h
dhcp-option=3,$GW_IP
dhcp-option=6,8.8.8.8
EOF

# Configurar WiFi
ip link set $WIFI down
ip link set $WIFI up
ip addr flush dev $WIFI
ip addr add $GW_IP/24 dev $WIFI

# IP forwarding
sysctl -w net.ipv4.ip_forward=1

# NAT con interfaz detectada
iptables -t nat -F
iptables -F FORWARD
iptables -t nat -A POSTROUTING -o $USB -j MASQUERADE
iptables -P FORWARD ACCEPT

# Matar anteriores
pkill -f hostapd 2>/dev/null || true
pkill -f dnsmasq 2>/dev/null || true
sleep 1

# Iniciar en screen
screen -dmS xtunnel bash -c "hostapd /tmp/hostapd.conf"
sleep 1
screen -S xtunnel -X screen bash -c "dnsmasq -C /tmp/dnsmasq.conf --no-daemon; bash"

echo "=============================="
echo "  WiFi: XTunnel-Test"
echo "  Sin contrasena"
echo "  Gateway: $GW_IP"
echo "  USB: $USB"
echo "=============================="
echo ""
echo "screen -r xtunnel para ver logs"
